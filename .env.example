# Cursor CLI uses LOCAL auth by default (`agent login` — no API key in .env required).
# Run once:  agent login   (pick your PERSONAL Cursor account in the browser)
# Switch account:  agent logout && agent login
# Optional:  CURSOR_AGENT_USE_LOGIN is implicit; only set CURSOR_AGENT_AUTH=api-key to force .env key.

# CURSOR_API_KEY=          # only if CURSOR_AGENT_AUTH=api-key
# CURSOR_AGENT_AUTH=local  # default — local login session
# CURSOR_AGENT_BIN=agent
# CURSOR_AGENT_MODEL=composer-2.5
# CURSOR_AGENT_TIMEOUT_MS=600000

# Optional — Imagen-3 when image-generation subagent needs raster assets
# GEMINI_API_KEY=              # Imagen images only (optional)
# ORCHESTRATOR_MODE=keywords   # default — fast local routing, one Cursor CLI run
# ORCHESTRATOR_MODE=cursor     # extra Cursor CLI call to pick subagent (~30–90s)
# ORCHESTRATOR_MODE=gemini     # Gemini API for routing
# ORCHESTRATOR_TIMEOUT_MS=120000
# ORCHESTRATOR_MODEL=          # optional; else CURSOR_AGENT_MODEL
