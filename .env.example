# Required — Google AI Studio / Gemini API key
GEMINI_API_KEY=

# Install harness deps: npm install @google/genai dotenv
# Dev: npm install --save-dev tsx typescript @types/node

# Optional: use a saved managed agent instead of inline Antigravity config
# Create one with: npm run agent:register
MANAGED_AGENT_ID=

# Optional: mount full GitHub repo into remote sandbox (instead of inline App.tsx only)
BETTER_SLIDO_REPO_URL=https://github.com/hardiktiwari/better_slido
